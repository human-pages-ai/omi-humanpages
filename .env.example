# Human Pages API key — get one at https://humanpages.ai or via the MCP server
HP_AGENT_KEY=hp_your_key_here

# OpenAI-compatible API for transcript analysis (optional — needed for auto-detect)
OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Omi app credentials (from Omi app store after publishing)
OMI_APP_ID=
OMI_APP_SECRET=

# Webhook secret for verifying Omi callbacks
WEBHOOK_SECRET=

# Public URL of this server (for HP callback webhooks)
BASE_URL=https://omi.humanpages.ai

# Secret for verifying HP callback signatures (min 16 chars)
CALLBACK_SECRET=hp_omi_callback_secret_min16chars

# SQLite database path
DB_PATH=/data/omi-hp.db
